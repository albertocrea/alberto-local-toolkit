#!/usr/bin/env python3
import subprocess
import os
import signal
import sys
import time

# Ajuste de PATH para encontrar herramientas de Homebrew y Python
os.environ["PATH"] = "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:" + os.environ.get("PATH", "")

TEMP_AUDIO = "/tmp/dictado_audio.wav"
PID_FILE = "/tmp/dictado.pid"
FFMPEG_PATH = "/opt/homebrew/bin/ffmpeg"
WHISPER_PATH = "/Users/albertoestevez/Library/Python/3.9/bin/mlx_whisper"

def get_running_pid():
    if os.path.exists(PID_FILE):
        try:
            with open(PID_FILE, "r") as f:
                return int(f.read().strip())
        except:
            return None
    return None

def is_pid_running(pid):
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True

def start_recording():
    # Usamos start_new_session=True para que ffmpeg siga vivo aunque el atajo termine
    # Redirigimos outputs a DEVNULL para evitar bloqueos por buffer lleno
    proc = subprocess.Popen([
        FFMPEG_PATH, "-y", "-f", "avfoundation", "-i", ":default", 
        "-t", "600", # Límite de 10 min
        TEMP_AUDIO
    ], stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL, start_new_session=True)
    
    with open(PID_FILE, "w") as f:
        f.write(str(proc.pid))
    
    subprocess.run(["osascript", "-e", 'display notification "🎙️ Grabando... Pulsa de nuevo para transcribir" with title "Dictado Whisper"'])

def stop_recording(pid):
    try:
        # Enviamos SIGINT para que ffmpeg guarde el archivo WAV correctamente
        os.kill(pid, signal.SIGINT)
        # Pequeña espera para que el proceso termine de escribir a disco
        for _ in range(10):
            if not is_pid_running(pid):
                break
            time.sleep(0.2)
    except:
        pass
    
    if os.path.exists(PID_FILE):
        os.remove(PID_FILE)

def transcribe_and_copy():
    # El archivo debe existir y tener un tamaño mínimo razonable (~10KB)
    if not os.path.exists(TEMP_AUDIO) or os.path.getsize(TEMP_AUDIO) < 10000:
        subprocess.run(["osascript", "-e", 'display notification "⚠️ Audio no capturado correctamente" with title "Dictado Whisper"'])
        return

    subprocess.run(["osascript", "-e", 'display notification "🤖 Transcribiendo..." with title "Dictado Whisper"'])
    
    try:
        # Capturamos la salida de Whisper
        result = subprocess.run([
            WHISPER_PATH, TEMP_AUDIO, 
            "--model", "mlx-community/whisper-large-v3-mlx", 
            "--language", "es"
        ], capture_output=True, text=True)
        
        raw_output = result.stdout.strip()
        
        # FILTRO: Whisper imprime configuración antes del texto real.
        # El texto real siempre viene después de una marca de tiempo estilo [00:00 -> 00:05]
        actual_text = []
        for line in raw_output.split("\n"):
            # Buscamos líneas que contengan marcas de tiempo reales
            if "->" in line and "]" in line:
                content = line.split("]")[-1].strip()
                if content:
                    actual_text.append(content)
        
        final_message = " ".join(actual_text)

        if final_message:
            # Copiar al portapapeles
            process = subprocess.Popen(['pbcopy'], stdin=subprocess.PIPE)
            process.communicate(input=final_message.encode('utf-8'))
            subprocess.run(["osascript", "-e", 'display notification "📋 Texto copiado con éxito" with title "Dictado Whisper"'])
        else:
            # Si el filtro falló pero hay salida, mostramos el error para depurar
            subprocess.run(["osascript", "-e", 'display notification "❌ No se detectó texto en el audio" with title "Dictado Whisper"'])
            
    except Exception as e:
        subprocess.run(["osascript", "-e", f'display notification "Error: {str(e)}" with title "Dictado Whisper"'])

if __name__ == "__main__":
    try:
        pid = get_running_pid()
        if pid and is_pid_running(pid):
            stop_recording(pid)
            transcribe_and_copy()
            if os.path.exists(TEMP_AUDIO):
                os.remove(TEMP_AUDIO)
        else:
            start_recording()
    except Exception as e:
        subprocess.run(["osascript", "-e", f'display notification "{str(e)}" with title "❌ Error Fatídico"'])
