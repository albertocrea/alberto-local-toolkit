#!/usr/bin/env python3
import subprocess
import os
import sys
import time

TEMP_AUDIO = "/tmp/dictado_audio.wav"

def record_audio():
    print("🎙️ Grabando... Presiona Ctrl+C para detener.")
    try:
        # Graba audio usando ffmpeg del micrófono predeterminado
        # -y sobreescribe, -f avfoundation para macOS, -i ":0" para micrófono predeterminado
        subprocess.run([
            "ffmpeg", "-y", "-f", "avfoundation", "-i", ":0", 
            "-t", "300", # Límite de 5 minutos
            TEMP_AUDIO
        ], stderr=subprocess.DEVNULL)
    except KeyboardInterrupt:
        print("\n⏹️ Grabación detenida.")

def transcribe():
    print("🤖 Transcribiendo...")
    try:
        # Ejecuta mlx_whisper
        result = subprocess.run([
            "mlx_whisper", TEMP_AUDIO, 
            "--model", "whisper-large-v3-mlx", 
            "--language", "es"
        ], capture_output=True, text=True)
        
        # mlx_whisper genera un archivo de texto o imprime por pantalla. 
        # Si imprime por pantalla, capturamos. Si genera archivo .txt, lo leemos.
        # Ajustamos para extraer solo el texto relevante.
        return result.stdout.strip()
    except Exception as e:
        print(f"❌ Error en transcripción: {e}")
        return None

def copy_to_clipboard(text):
    process = subprocess.Popen(['pbcopy'], stdin=subprocess.PIPE)
    process.communicate(input=text.encode('utf-8'))

def paste_text():
    # Uso de AppleScript para pegar el contenido del portapapeles en la app activa
    script = 'tell application "System Events" to keystroke "v" using {command down}'
    subprocess.run(["osascript", "-e", script])

def cleanup():
    if os.path.exists(TEMP_AUDIO):
        os.remove(TEMP_AUDIO)

if __name__ == "__main__":
    try:
        record_audio()
        text = transcribe()
        if text:
            print(f"📝 Texto transcribido: {text}")
            copy_to_clipboard(text)
            # Pequeña pausa para asegurar que el sistema procesa el portapapeles
            time.sleep(0.5)
            paste_text()
            print("✅ Texto pegado con éxito.")
        else:
            print("⚠️ No se generó texto de la grabación.")
    finally:
        cleanup()
